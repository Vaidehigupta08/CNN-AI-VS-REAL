# ---------- Streamlit Frontend ----------
FROM python:3.10-slim

WORKDIR /app

# Install only frontend dependencies (no TensorFlow needed)
RUN pip install --no-cache-dir \
    streamlit==1.38.0 \
    requests==2.32.3 \
    pillow==10.4.0

# Copy frontend code
COPY app.py .

EXPOSE 8501

CMD ["streamlit", "run", "app.py", "--server.port=8501", "--server.address=0.0.0.0", "--server.headless=true"]
